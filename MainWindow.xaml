<Window x:Class="TextToAudiobookCSharp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Text to Audiobook v14.4 — Online + Piper + Offline"
        Width="760" Height="870" MinWidth="720" MinHeight="780"
        Background="{DynamicResource BgDarkBrush}"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" MinHeight="180" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="1.2*" MinHeight="150" />
        </Grid.RowDefinitions>

        <!-- ═══ Шапка ═══ -->
        <Border Grid.Row="0" Background="{DynamicResource AccentBrush}" Padding="24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Text to Audiobook  v14.4"
                           FontSize="26" FontWeight="Bold"
                           Foreground="{DynamicResource HeaderTextBrush}"
                           VerticalAlignment="Center" />
                <Button x:Name="BtnCheckUpdate" Grid.Column="1"
                        Content="{DynamicResource Loc_Update}" Height="40" Padding="16,0"
                        VerticalAlignment="Center"
                        Background="White" Foreground="{DynamicResource AccentBrush}"
                        Style="{StaticResource RoundButton}"
                        Click="BtnCheckUpdate_Click" />
                <Button x:Name="BtnSettings" Grid.Column="2"
                        Content="⚙" FontSize="20" Width="46" Height="40" Margin="10,0,0,0"
                        VerticalAlignment="Center"
                        Background="White" Foreground="{DynamicResource AccentBrush}"
                        Style="{StaticResource RoundButton}"
                        ToolTip="{DynamicResource Loc_Settings}"
                        Click="BtnSettings_Click" />
            </Grid>
        </Border>

        <!-- ═══ Верхняя панель: настройки (скроллируемая) ═══ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="24,14,24,0">
            <StackPanel>

                <!-- ═══ Баннер «Продолжить» ═══ -->
                <Border x:Name="ResumeCard" Visibility="Collapsed"
                        Background="{DynamicResource ResumeBgBrush}" CornerRadius="14"
                        BorderBrush="{DynamicResource SuccessBrush}" BorderThickness="1"
                        Padding="16,12" Margin="0,8,0,3">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="ResumeLabel" Grid.Column="0"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="{DynamicResource SuccessBrush}"
                                   VerticalAlignment="Center" />
                        <Button x:Name="BtnResume" Grid.Column="1"
                                Content="{DynamicResource Loc_Continue}" Width="120" Height="34"
                                Background="{DynamicResource SuccessBrush}"
                                Style="{StaticResource RoundButton}"
                                Click="BtnResume_Click" />
                    </Grid>
                </Border>

                <!-- ═══ Недавние книги ═══ -->
                <Border x:Name="HistoryCard" Visibility="Collapsed"
                        Background="{DynamicResource BgCardBrush}" CornerRadius="14"
                        Padding="16,12" Margin="0,3">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{DynamicResource Loc_RecentBooks}" FontSize="15" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentBrush}"
                                   VerticalAlignment="Center" Margin="0,0,12,0" />
                        <ComboBox x:Name="ComboHistory" Width="420"
                                  Style="{StaticResource DarkComboBox}"
                                  SelectionChanged="ComboHistory_SelectionChanged" />
                    </StackPanel>
                </Border>

                <!-- ═══ Карточка: Исходный файл ═══ -->
                <Border Background="{DynamicResource BgCardBrush}" CornerRadius="14"
                        Padding="16,12" Margin="0,3">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Loc_SourceFile}" FontSize="15" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,6" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtInputFile" Grid.Column="0"
                                     Style="{StaticResource DarkTextBox}" Height="38" />
                            <Button Grid.Column="1" Content="{DynamicResource Loc_Browse}" Width="90" Height="38"
                                    Background="{DynamicResource AccentBrush}"
                                    Style="{StaticResource RoundButton}" Margin="10,0,0,0"
                                    Click="BtnBrowseInput_Click" />
                            <Button Grid.Column="2" Content="{DynamicResource Loc_Folder}" Width="90" Height="38"
                                    Background="{DynamicResource BgInputBrush}"
                                    Foreground="{DynamicResource TextSecondaryBrush}"
                                    Style="{StaticResource RoundButton}" Margin="8,0,0,0"
                                    Click="BtnOpenInputFolder_Click" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ═══ Карточка: Папка сохранения ═══ -->
                <Border Background="{DynamicResource BgCardBrush}" CornerRadius="14"
                        Padding="16,12" Margin="0,3">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Loc_OutputFolder}" FontSize="15" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,6" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtOutputDir" Grid.Column="0"
                                     Style="{StaticResource DarkTextBox}" Height="38" />
                            <Button Grid.Column="1" Content="{DynamicResource Loc_Browse}" Width="90" Height="38"
                                    Background="{DynamicResource AccentBrush}"
                                    Style="{StaticResource RoundButton}" Margin="10,0,0,0"
                                    Click="BtnBrowseOutput_Click" />
                            <Button Grid.Column="2" Content="{DynamicResource Loc_Folder}" Width="90" Height="38"
                                    Background="{DynamicResource BgInputBrush}"
                                    Foreground="{DynamicResource TextSecondaryBrush}"
                                    Style="{StaticResource RoundButton}" Margin="8,0,0,0"
                                    Click="BtnOpenOutputFolder_Click" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ═══ Карточка: Настройки конвертации ═══ -->
                <Border Background="{DynamicResource BgCardBrush}" CornerRadius="14"
                        Padding="16,12" Margin="0,3">
                    <StackPanel>
                        <!-- Режим TTS -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{DynamicResource Loc_Mode}" FontSize="14"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" />
                            <ComboBox x:Name="ComboTtsMode" Grid.Column="1" Width="280"
                                      Style="{StaticResource DarkComboBox}"
                                      SelectionChanged="ComboTtsMode_SelectionChanged" />
                            <TextBlock x:Name="LblModeStatus" Grid.Column="2"
                                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="12,0,0,0" />
                        </Grid>

                        <!-- Голос -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{DynamicResource Loc_Voice}" FontSize="14"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" />
                            <ComboBox x:Name="ComboVoice" Grid.Column="1"
                                      Style="{StaticResource DarkComboBox}" />
                        </Grid>

                        <!-- Скорость -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="50" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{DynamicResource Loc_Speed}" FontSize="14"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" />
                            <Slider x:Name="SliderSpeed" Grid.Column="1"
                                    Minimum="-50" Maximum="50" Value="0"
                                    TickFrequency="10" IsSnapToTickEnabled="True"
                                    VerticalAlignment="Center"
                                    ValueChanged="SliderSpeed_ValueChanged" />
                            <TextBlock x:Name="LblSpeed" Grid.Column="2" Text="+0%"
                                       FontSize="13" FontWeight="Bold"
                                       Foreground="{DynamicResource AccentBrush}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center" />
                        </Grid>

                        <!-- Кодировка -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{DynamicResource Loc_Encoding}" FontSize="14"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" />
                            <ComboBox x:Name="ComboEncoding" Grid.Column="1"
                                      Style="{StaticResource DarkComboBox}" />
                        </Grid>

                        <!-- Чекбоксы -->
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <CheckBox x:Name="ChkMerge" Content="{DynamicResource Loc_Merge}"
                                      IsChecked="True"
                                      Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13"
                                      Margin="0,0,24,0" />
                            <CheckBox x:Name="ChkNoChapters" Content="{DynamicResource Loc_NoChapters}"
                                      Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <CheckBox x:Name="ChkDeleteFragments" Content="{DynamicResource Loc_DeleteFragments}"
                                      IsChecked="False"
                                      Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ═══ Кнопки управления ═══ -->
                <Grid Margin="0,6,0,3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button x:Name="BtnOpenFolder" Grid.Column="0"
                            Content="{DynamicResource Loc_OpenFolder}" Height="42" Padding="14,8"
                            Background="{DynamicResource BgInputBrush}"
                            Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="Normal"
                            Style="{StaticResource RoundButton}"
                            Click="BtnOpenFolder_Click" />

                    <Button x:Name="BtnPause" Grid.Column="1"
                            Content="{DynamicResource Loc_Pause}" Height="42" Width="110" Margin="10,0,0,0"
                            Background="{DynamicResource WarningBrush}"
                            Style="{StaticResource RoundButton}"
                            IsEnabled="False"
                            Click="BtnPause_Click" />

                    <Button x:Name="BtnStop" Grid.Column="2"
                            Content="{DynamicResource Loc_Stop}" Height="42" Width="90" Margin="10,0,0,0"
                            Background="{DynamicResource DangerBrush}"
                            Style="{StaticResource RoundButton}"
                            IsEnabled="False"
                            Click="BtnStop_Click" />

                    <Button x:Name="BtnStart" Grid.Column="5"
                            Content="{DynamicResource Loc_Start}" Height="42" Padding="20,8"
                            Background="{DynamicResource AccentBrush}"
                            Style="{StaticResource RoundButton}"
                            Click="BtnStart_Click" />
                </Grid>

            </StackPanel>
        </ScrollViewer>

        <!-- ═══ Разделитель (перетаскиваемый) ═══ -->
        <GridSplitter Grid.Row="2" Height="6" HorizontalAlignment="Stretch"
                       Background="{DynamicResource SplitterBrush}" Margin="24,2" />

        <!-- ═══ Нижняя панель: Прогресс и лог ═══ -->
        <Border Grid.Row="3" Background="{DynamicResource BgCardBrush}" CornerRadius="14"
                Padding="16,12" Margin="24,3,24,16">
            <DockPanel>
                <!-- Заголовок прогресса -->
                <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{DynamicResource Loc_Progress}" FontSize="15" FontWeight="Bold"
                               Foreground="{DynamicResource AccentBrush}" />
                    <TextBlock x:Name="LblEta" Grid.Column="2" FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,0,16,0" />
                    <TextBlock x:Name="LblPercent" Grid.Column="3" Text="0%"
                               FontSize="13" FontWeight="Bold"
                               Foreground="{DynamicResource AccentBrush}" />
                </Grid>

                <!-- Прогресс-бар -->
                <Border DockPanel.Dock="Top" CornerRadius="5" Height="10"
                        Background="{DynamicResource BgInputBrush}" Margin="0,0,0,8">
                    <Border x:Name="ProgressFill" CornerRadius="5" Height="10"
                            Background="{DynamicResource AccentBrush}"
                            HorizontalAlignment="Left" Width="0" />
                </Border>

                <!-- Шрифт лога -->
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="{DynamicResource Loc_LogFont}" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0" />
                    <ComboBox x:Name="ComboLogFont" Width="170"
                              Style="{StaticResource DarkComboBox}"
                              SelectionChanged="ComboLogFont_SelectionChanged" />
                    <TextBlock Text="{DynamicResource Loc_Size}" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="16,0,8,0" />
                    <ComboBox x:Name="ComboLogFontSize" Width="70"
                              Style="{StaticResource DarkComboBox}"
                              SelectionChanged="ComboLogFontSize_SelectionChanged" />
                </StackPanel>

                <!-- Лог -->
                <TextBox x:Name="TxtLog" IsReadOnly="True"
                         TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         Background="{DynamicResource LogBgBrush}"
                         Foreground="{DynamicResource LogFgBrush}"
                         FontFamily="Consolas" FontSize="14"
                         BorderThickness="0" Padding="12,8"
                         VerticalAlignment="Stretch" />
            </DockPanel>
        </Border>

    </Grid>
</Window>
